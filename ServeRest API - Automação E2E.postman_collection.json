          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"Rafael Augusto QA\",\r\n  \"email\": \"{{emailDinamico}}\",\r\n  \"password\": \"senha_super_secreta\",\r\n  \"administrador\": \"true\"\r\n}",
